#using hashmap

#include <vector>
#include <unordered_map>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> mp;

        for (int i = 0; i < nums.size(); i++) {
            int searchingFor = target - nums[i];

            if (mp.find(searchingFor) != mp.end()) {
                return {mp[searchingFor], i};
            }

            mp[nums[i]] = i;
        }

        return {-1, -1};
    }
};
