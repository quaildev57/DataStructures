//T.C = O(n); Space=O(1)

class Solution {
public:
    bool isPalindrome(string s) {
        int i = 0;
        int j = s.length()-1;
        while(i<j){
            char left = s[i];
            char right = s[j];
            if(!isdigit(left) && !isalpha(left)){
                i++;
                continue;// skips this iteration
            }
            if(!isdigit(right) && !isalpha(right)){
                j--;
                continue;// skips this iteration
            }
            if(tolower(left)!=tolower(right)){
                return false;
            }
            i++;
            j--;

        }
        return true;
    }
};
