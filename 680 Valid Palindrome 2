class Solution {
    public: bool palindromeHelp(int i, int j, string s){
        while(i<j){
            if(s[i]!=s[j]){
                return false;
            }
            i++;
            j--;
        }
        return true;
    }
    //T: O(n) and Space: O(1)
    
public:
    bool validPalindrome(string s) {
        int i = 0;
        int j = s.length()-1;
        while(i<j){
            char left = s[i];
            char right = s[j];
            if(left!=right){
                //use your suerpower of deleting one char
                //this can be used only once since only one deletion allowed
                return palindromeHelp(i+1,j,s)|| palindromeHelp(i,j-1,s);
                
            }
            else{
               i++;
                j--;
            }
        }
        return true;
    }
};
